NODE_ENV=development
PORT=3000
SWAGGER_ENABLED=true

# Example (docker-compose below uses these defaults):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/schooldev?schema=identity&sslmode=require"

# 32 bytes key, base64-encoded (AES-256-GCM). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY=""

# 32 bytes key, base64-encoded (HMAC-SHA256). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_HMAC_KEY=""

# JWT
JWT_SECRET=""
JWT_EXPIRES_IN="15m"

# One-time bootstrap token for creating first SUPER_ADMIN (dev/provisioning only)
BOOTSTRAP_TOKEN=""

# When true, enables POST /auth/bootstrap/super-admin (and shows it in Swagger)
BOOTSTRAP_SUPER_ADMIN_HTTP_ENABLED=false

